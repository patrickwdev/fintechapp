# Plaid Dashboard → Team Settings → Keys (https://dashboard.plaid.com/team/api)
# Use the Sandbox client_id and Sandbox secret — not Development or Production.
# You can put these in this file OR in the repo root .env (server loads both; this file wins if both set).
PLAID_CLIENT_ID=your_sandbox_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox

# Dwolla: Plaid Dashboard → Developers → Integrations → enable Dwolla (required for processor tokens).

# Optional (default 3001)
# PORT=3001
