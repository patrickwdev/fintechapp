# Supabase (get these from https://app.supabase.com → Project Settings → API)
# Copy to .env and fill in your project URL and anon key.
# For signup verification emails: Auth → Providers → Email → enable "Confirm email".
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Plaid: URL of the Express server in /server (default port 3001). Run it with `npm run server:plaid` or use `npm run dev:with-plaid` to start Expo and the Plaid API together.
EXPO_PUBLIC_PLAID_BACKEND_URL=http://localhost:3001
